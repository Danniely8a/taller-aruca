{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/ver/(.*)", "dest": "/api/index.py" },
    { "src": "/ot/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*\\.(js|css|png|jpg|ico|svg|json|woff|woff2|ttf|eot))", "dest": "/frontend/dist/$1" },
    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ]
}
